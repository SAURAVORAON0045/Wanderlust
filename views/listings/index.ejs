<% layout("/layouts/boilerplate") %>
<style>
    #filters{
        display: flex;
        flex-wrap: nowrap;
        overflow-x:auto;
        align-items: center;
        scrollbar-width: none;
    }

.tax-toggle {
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.25rem;
    padding: 1rem;
    margin-left: auto; /* Pushes the toggle to the far right */
    display: flex;
    align-items: center;
    white-space: nowrap; /* Prevents text from breaking into two lines */
}

.tax-switch {
    display: flex;
    align-items: center;
}


    .filter{
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
        opacity: 0.7;
        flex-shrink: 0;
        
    }
    .filter:hover{
        opacity: 1;
        cursor: pointer; 
    }
    .filter p {
        font-size: 0.8rem;

    }
    #filters::-webkit-scrollbar{
        display: none;

    }
    #filters{
        -ms-overflow-style:none;
        scrollbar-width: none;
    }
    .tax-info{
        display: none;
    }
    .tax-toggle{
        border: 1px solid black;
        border-radius: 1rem;
        height: 3.25rem;
        padding: 1rem;
        margin-left: 3rem;
        display: flex;
        align-items: center;
        width: fit-content;
        max-width: 100%;
    }
    .no{
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        height: 60vh;
        width: 100%;

    }
    .filter-link {
    text-decoration: none;
    color: inherit; /* Keeps the text black/gray */
    opacity: 0.7;
    transition: 0.2s;
}

.filter-link:hover {
    opacity: 1;
}




</style>
